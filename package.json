{
	"name": "gooey-toast",
	"version": "0.2.2",
	"description": "A framework-agnostic, physics-inspired toast notification library.",
	"license": "MIT",
	"keywords": [
		"toast",
		"notification",
		"vue",
		"react",
		"svelte",
		"javascript",
		"typescript"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/janusfil/gooey-toast.git"
	},
	"homepage": "https://github.com/janusfil/gooey-toast#readme",
	"bugs": {
		"url": "https://github.com/janusfil/gooey-toast/issues"
	},
	"sideEffects": [
		"./dist/styles.css"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./styles.css": "./dist/styles.css"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"engines": {
		"node": ">=18"
	},
	"files": [
		"dist"
	],
	"packageManager": "npm@10.8.2",
	"scripts": {
		"clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
		"build:ts": "tsc",
		"build:css": "node -e \"require('node:fs').copyFileSync('src/styles.css', 'dist/styles.css')\"",
		"build": "npm run clean && npm run build:ts && npm run build:css",
		"check:package": "npm pack --dry-run",
		"check:supply-chain": "node ./scripts/check-supply-chain.mjs",
		"demo:build": "node ./scripts/build-demo.mjs",
		"test:fuzz": "node --test test/**/*.test.cjs",
		"prepublishOnly": "npm run build",
		"dev": "tsc --watch --preserveWatchOutput",
		"playground": "esbuild playground/main.ts --bundle --outfile=playground/.build/main.js --format=esm --platform=browser --target=es2020 --sourcemap --servedir=. --serve=8080 --watch",
		"playground:build": "esbuild playground/main.ts --bundle --outfile=playground/.build/main.js --format=esm --platform=browser --target=es2020 --sourcemap"
	},
	"devDependencies": {
		"esbuild": "^0.27.3",
		"fast-check": "^4.6.0",
		"typescript": "^5.9.2"
	}
}
